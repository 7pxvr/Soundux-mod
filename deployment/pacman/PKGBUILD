# Maintainer: 7pxvr

pkgname=soundux-mod
pkgver=0.2.8
pkgrel=1
pkgdesc="A cross-platform soundboard with native Wayland-focused fixes"
arch=('x86_64')
url="https://github.com/7pxvr/Soundux-mod"
license=('GPL-3.0-only')
depends=(
  'brotli'
  'gtk3'
  'hicolor-icon-theme'
  'libappindicator-gtk3'
  'libpulse'
  'libwnck3'
  'libx11'
  'libxi'
  'libxtst'
  'openssl'
  'pipewire'
  'qt6-base'
  'qt6-webchannel'
  'qt6-webengine'
  'zlib'
)
makedepends=(
  'cmake'
  'git'
  'ninja'
  'pkgconf'
)
provides=('soundux')
conflicts=('soundux' 'soundux-git')
options=('!debug')
source=()
sha256sums=()

build() {
  local source_dir="${SOUNDUX_SOURCE_DIR:-${startdir}/../..}"

  cmake -S "${source_dir}" -B build -G Ninja \
    -DCMAKE_BUILD_TYPE=Release
  cmake --build build
}

package() {
  local source_dir="${SOUNDUX_SOURCE_DIR:-${startdir}/../..}"

  DESTDIR="${pkgdir}" cmake --install build

  install -Dm644 "${source_dir}/LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  install -d "${pkgdir}/usr/bin"
  ln -s /opt/soundux/soundux "${pkgdir}/usr/bin/soundux"
  ln -s /opt/soundux/soundux "${pkgdir}/usr/bin/soundux-mod"
}
